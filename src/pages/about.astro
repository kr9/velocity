---
import PageLayout from '@/layouts/PageLayout.astro';
import { Hero } from '@/components/hero';
import siteConfig from '@/config/site.config';
---

<PageLayout title="About" description={`About ${siteConfig.author}`}>
  <Hero layout="centered" size="sm" showGrid>
    <h1 slot="title">About</h1>
    <p slot="description">A little about me and this blog.</p>
  </Hero>

  <section class="py-16">
    <div class="mx-auto max-w-2xl px-6 prose prose-lg dark:prose-invert">
      <p>
        Hi, I'm {siteConfig.author}. This is my personal corner of the web for
        writing down ideas, insights, and stories.
      </p>
      <p>
        Replace this placeholder with your own bio — what you do, what you're
        working on, and how readers can get in touch.
      </p>
    </div>
  </section>
</PageLayout>
