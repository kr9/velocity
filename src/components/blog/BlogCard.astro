---
/**
 * BlogCard — design-system version
 *
 * Borderless, no shadow, no card chrome. A post row separated from the next
 * by a hairline. Title goes accent on hover. Tag chips use accent-muted bg.
 * Used by the homepage, /blog index, and RelatedPosts grid.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { formatDate } from '@/lib/utils';

interface Props {
  title: string;
  description: string;
  href: string;
  publishedAt: Date;
  tags?: string[];
  featured?: boolean;
  author?: string;
  image?: ImageMetadata;
}

const {
  title,
  description,
  href,
  publishedAt,
  tags = [],
  author,
  image,
} = Astro.props;

const wordsPerMinute = 200;
const estimatedWords = description.split(' ').length * 10;
const readingTime = Math.max(1, Math.ceil(estimatedWords / wordsPerMinute));
---

<article class="blog-card">
  <a href={href} class="blog-card__link">
    {image && (
      <div class="blog-card__image-wrap">
        <Image
          src={image}
          alt={title}
          widths={[320, 640, 960]}
          sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 400px"
          class="blog-card__image"
          loading="lazy"
        />
      </div>
    )}

    <h2 class="blog-card__title">{title}</h2>

    <p class="blog-card__excerpt">{description}</p>

    <div class="blog-card__meta">
      {author && <span>{author}</span>}
      <time datetime={publishedAt.toISOString()}>{formatDate(publishedAt)}</time>
      <span>{readingTime} min read</span>
    </div>

    {tags.length > 0 && (
      <div class="blog-card__tags">
        {tags.slice(0, 3).map((tag) => (
          <span class="tag-chip">{tag}</span>
        ))}
      </div>
    )}
  </a>
</article>

<style>
  .blog-card {
    padding: 24px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .blog-card:last-child {
    border-bottom: none;
  }

  .blog-card__link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .blog-card__image-wrap {
    overflow: hidden;
    border-radius: 8px;
    margin-bottom: 16px;
  }

  .blog-card__image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .blog-card__title {
    font-size: 1.25rem;       /* 20px */
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-foreground);
    margin-bottom: 8px;
    transition: color 150ms ease-out;
  }

  .blog-card__link:hover .blog-card__title {
    color: var(--accent);
  }

  .blog-card__excerpt {
    font-size: 1rem;          /* 16px */
    line-height: 1.5;
    color: var(--color-foreground-secondary);
    margin: 0 0 16px;
  }

  .blog-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    font-size: 0.875rem;      /* 14px */
    color: var(--color-foreground-secondary);
  }

  .blog-card__meta > * + *::before {
    content: '·';
    margin-right: 16px;
  }

  .blog-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    background-color: var(--accent-muted);
    color: var(--accent);
    font-size: 0.8125rem;     /* 13px */
    font-weight: 500;
    border-radius: 6px;
    transition: background-color 150ms ease-out;
  }

  .blog-card__link:hover .tag-chip {
    background-color: var(--accent-muted-hover);
  }
</style>
