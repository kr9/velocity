---
/**
 * ArticleHero — design-system version
 *
 * Simple, borderless article header per the design system:
 *   Tags (accent-muted chips, optional)
 *   Title (32px semibold)
 *   Description (16px secondary)
 *   Author · Date · Read time (14px secondary)
 *   ─── hairline ───
 *   Optional featured image (full reading column, 8px radius, no shadow)
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { formatDate } from '@/lib/utils';

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  author?: string;
  tags?: string[];
  image?: ImageMetadata;
  imageAlt?: string;
}

const {
  title,
  description,
  publishedAt,
  updatedAt,
  author = 'Team',
  tags = [],
  image,
  imageAlt,
} = Astro.props;

const wordsPerMinute = 200;
const estimatedWords = description.split(' ').length * 15;
const readingTime = Math.max(1, Math.ceil(estimatedWords / wordsPerMinute));
---

<header class="article-hero">
  <div class="article-hero__inner">
    {tags.length > 0 && (
      <div class="article-hero__tags">
        {tags.map((tag) => (
          <span class="tag-chip">{tag}</span>
        ))}
      </div>
    )}

    <h1 class="article-hero__title">{title}</h1>

    <p class="article-hero__description">{description}</p>

    <div class="article-hero__meta">
      <span>{author}</span>
      <time datetime={publishedAt.toISOString()}>{formatDate(publishedAt)}</time>
      {updatedAt && (
        <time datetime={updatedAt.toISOString()}>Updated {formatDate(updatedAt)}</time>
      )}
      <span>{readingTime} min read</span>
    </div>
  </div>

  {image && (
    <div class="article-hero__image-wrap">
      <Image
        src={image}
        alt={imageAlt || title}
        widths={[640, 960, 1280, 1920]}
        sizes="(max-width: 768px) 100vw, 660px"
        class="article-hero__image"
        loading="eager"
      />
    </div>
  )}
</header>

<style>
  .article-hero {
    padding-top: var(--space-page-top);
    padding-bottom: 32px;
  }

  .article-hero__inner {
    max-width: 660px;
    margin-inline: auto;
    padding-inline: 24px;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 32px;
  }

  .article-hero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    background-color: var(--accent-muted);
    color: var(--accent);
    font-size: 0.8125rem;
    font-weight: 500;
    border-radius: 6px;
  }

  .article-hero__title {
    font-size: 2rem;          /* 32px */
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-foreground);
    margin: 0 0 16px;
  }

  .article-hero__description {
    font-size: 1rem;
    line-height: 1.5;
    color: var(--color-foreground-secondary);
    margin: 0 0 24px;
  }

  .article-hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    font-size: 0.875rem;
    color: var(--color-foreground-secondary);
  }

  .article-hero__meta > * + *::before {
    content: '·';
    margin-right: 16px;
  }

  .article-hero__image-wrap {
    max-width: 660px;
    margin: 32px auto 0;
    padding-inline: 24px;
  }

  .article-hero__image {
    width: 100%;
    border-radius: 8px;
    display: block;
  }
</style>
